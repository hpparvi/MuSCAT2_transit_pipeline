import warnings
import logging
from os.path import basename
from argparse import ArgumentParser
from muscat2ph.organizer import LCOOrganizer

from astropy.utils.exceptions import AstropyWarning

if __name__ == '__main__':
    ap = ArgumentParser()
    ap.add_argument('rawdir', type=str)
    ap.add_argument('orgdir', type=str)
    ap.add_argument('-c', '--check-only', action='store_true', default=False)
    ap.add_argument('-s', '--skip-existing', action='store_true', default=False)
    args = ap.parse_args()

    warnings.simplefilter('ignore', category=AstropyWarning)
    logging.basicConfig(filename='lcoorganize_{}.log'.format(basename(args.rawdir)), filemode='w', level=logging.DEBUG)

    mo = LCOOrganizer(args.rawdir, args.orgdir, args.skip_existing)
    if not args.check_only:
        mo.organize()
    #mo.check(args.check_only)